{
    "name": "sbine/route-viewer",
    "description": "A Laravel Nova tool to view your registered routes.",
    "license": "MIT",
    "keywords": [
        "laravel",
        "nova",
        "routes"
    ],
    "authors": [
        {
            "name": "Sara Bine",
            "role": "Developer"
        }
    ],
    "homepage": "https://github.com/sbine/nova-route-viewer",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0 || ^12.0 || ^13.0",
        "laravel/nova": "^5.0"
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://nova.laravel.com",
            "only": [
                "laravel/nova"
            ]
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require-dev": {
        "phpunit/phpunit": "^11.0 || ^12.0"
    },
    "autoload": {
        "psr-4": {
            "Sbine\\RouteViewer\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Sbine\\RouteViewer\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "Sbine\\RouteViewer\\ToolServiceProvider"
            ]
        }
    }
}
